# Copy to one.env. Keep one.env private and never commit it.
POSTFORGE_URL=https://postforge-ai-one.vercel.app
POSTFORGE_API_SECRET=
ONE_ROUTER_MODEL=llama3.1:8b
ONE_ENGINE=ollama
ONE_AGENT=react
ONE_FAST_LOCAL_MODEL=qwen3.5:2b
ONE_HEAVY_LOCAL_MODEL=qwen3.6:latest
ONE_RTX_REASONING_MODEL=llama3.1:8b
# Heavy tier — do not set ONE_ENGINE=nvidia here. one_agents jobs are fast-tier
# (this file's ONE_ENGINE/ONE_ROUTER_MODEL) by default and only escalate to
# Nemotron when a job explicitly requests tier=heavy (agent_network tool, or
# saying "heavy"/"escalate"/"use nemotron" in chat) — see
# one_agents/runtime.py:_resolve_planner_model. Set NEMOTRON_MODEL to the
# exact model id from NVIDIA's catalog so the heavy tier is *reachable*;
# leaving ONE_ENGINE=ollama keeps it from being the default.
# Save NVIDIA_API_KEY with set-nvidia-nemotron.ps1; do not put secrets in this file.
NEMOTRON_MODEL=
NVIDIA_HOST=https://integrate.api.nvidia.com
# Image generation default is OpenAI — simpler (no local server to keep
# running), no Hugging Face gated-model approval needed. Local FLUX stays
# wired below as an opt-in, free alternative: set ONE_IMAGE_PROVIDER=flux and
# ONE_FLUX_AUTOSTART=true if/when you want image generation running locally.
ONE_IMAGE_PROVIDER=openai
ONE_IMAGE_FALLBACK_OPENAI=true
ONE_FLUX_AUTOSTART=false
ONE_FLUX_URL=http://127.0.0.1:8188
ONE_FLUX_MODEL=black-forest-labs/FLUX.1-schnell
ONE_FLUX_STEPS=4
ONE_FLUX_GUIDANCE_SCALE=0.0
ONE_FLUX_TIMEOUT_SECONDS=1800
# Save HF_TOKEN/HUGGINGFACE_HUB_TOKEN with set-flux-hf-token.ps1 if you switch
# ONE_IMAGE_PROVIDER to flux; do not put secrets in this file.
TITAN_DEFAULT_PILLAR=news

# Optional ALFA revenue settings. Use a hosted payment link from your provider.
ALFA_PAYMENT_LINK=
# Random local secret used by n8n/payment adapters to sign x-one-signature.
ALFA_PAYMENT_WEBHOOK_SECRET=

# Optional JOBHUNT settings. JOBHUNT prepares drafts only; it never applies or sends without approval.
JOBHUNT_AUTOSCOUT=true
JOBHUNT_SCAN_INTERVAL_SECONDS=86400
JOBHUNT_MIN_FIT_SCORE=55
